# mind-landing-v0 — public marketing site for mindpods.org
#
# These NEXT_PUBLIC_* values are inlined at BUILD time (see Dockerfile +
# .github/workflows/release.yml). For local `npm run dev` the defaults baked
# into src/lib/links.ts are used, so a .env.local is optional.

# Where the primary "Create your pod" CTA sends a new user — the live
# CommunitySolidServer self-serve account/pod registration page.
NEXT_PUBLIC_POD_REGISTER_URL=https://pod.mindpods.org/.account/login/password/register/

# The post-login front door (the dock) — secondary "Sign in" CTA.
NEXT_PUBLIC_APP_DOCK_URL=https://dock.mindpods.org

# Live sibling apps featured on /apps.
NEXT_PUBLIC_APP_DRIVE_URL=https://drive.mindpods.org
NEXT_PUBLIC_APP_BUILDER_URL=https://builder.mindpods.org
NEXT_PUBLIC_APP_CODESPACES_URL=https://codespaces.mindpods.org

# The published architecture / protocol spec (external).
NEXT_PUBLIC_DOCS_URL=https://mind-studio.github.io/mind-specification/
