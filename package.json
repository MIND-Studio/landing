{
  "name": "landing",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3090",
    "gen:icons": "node scripts/gen-icons.mjs",
    "build": "next build",
    "start": "next start --port 3090",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run --passWithNoTests",
    "prepare": "husky"
  },
  "dependencies": {
    "@mind-studio/ui": "^0.6.0",
    "next": "16.2.6",
    "next-themes": "^0.4.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  }
}
